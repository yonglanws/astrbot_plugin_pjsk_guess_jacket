{
  "answer_timeout": {
    "description": "答题时长（秒）",
    "type": "int",
    "default": 30,
    "hint": "设置玩家回答问题的超时时间，单位为秒"
  },
  "daily_play_limit": {
    "description": "每位玩家每日可参与游戏的次数上限（-1表示无限制）",
    "type": "int",
    "default": 10,
    "hint": "设置每个用户每天可以玩几次游戏。设置为-1表示无限制"
  },
  "super_users": {
    "description": "管理员用户ID列表",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "在此处添加管理员的用户ID（字符串形式），他们将有权限使用管理员指令"
  },
  "blacklist": {
    "description": "黑名单用户ID列表",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "在此处添加被拉黑用户的ID（字符串形式），这些用户将无法使用插件功能"
  },
  "group_whitelist": {
    "description": "群聊白名单",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "在此处添加允许使用此插件的群聊ID。如果列表为空，则所有群聊都允许使用"
  },
  "whitelist_reject_message": {
    "description": "非白名单群聊的提示文本",
    "type": "string",
    "default": "⚠️ 抱歉，当前群聊未在白名单中，无法使用此功能。如需使用，请联系管理员将本群添加到白名单。",
    "hint": "当非白名单群聊的用户尝试触发游戏时，向其显示的提示信息。留空则不提示。"
  },
  "game_cooldown_seconds": {
    "description": "游戏冷却时间（秒）",
    "type": "int",
    "default": 10,
    "hint": "游戏结束后需要等待的时间才能开始下一局"
  },
  "ranking_display_count": {
    "description": "排行榜显示的人数",
    "type": "int",
    "default": 10,
    "hint": "设置排行榜要显示的玩家数量，建议范围：5-20"
  },
  "effects": {
    "description": "图片效果配置",
    "type": "object",
    "default": {},
    "items": {
      "blur": {
        "description": "模糊效果配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用模糊效果"
          },
          "difficulty": {
            "type": "int",
            "default": 1,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "blur_radius": {
            "type": "int",
            "default": 35,
            "description": "模糊半径",
            "hint": "控制模糊效果的强度，值越大越模糊"
          }
        }
      },
      "random_crop": {
        "description": "随机裁切效果配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用随机裁切效果"
          },
          "difficulty": {
            "type": "int",
            "default": 1,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "crop_ratio": {
            "type": "float",
            "default": 0.3,
            "description": "裁切比例",
            "hint": "控制显示区域的比例，范围0.1-0.6，值越小显示区域越小"
          }
        }
      },
      "glitch": {
        "description": "损坏效果配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用损坏效果"
          },
          "difficulty": {
            "type": "int",
            "default": 2,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "glitch_intensity": {
            "type": "float",
            "default": 1.0,
            "description": "损坏强度",
            "hint": "控制损坏效果的强度，范围0.5-3.0，值越大损坏越严重"
          }
        }
      },
      "shuffle_blocks_easy": {
        "description": "分块打乱(简易)配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用分块打乱(简易)效果"
          },
          "difficulty": {
            "type": "int",
            "default": 1,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "block_size": {
            "type": "int",
            "default": 50,
            "description": "区块大小",
            "hint": "控制方块的大小，值越大方块越大，打乱程度越低"
          }
        }
      },
      "shuffle_blocks_hard": {
        "description": "分块打乱(困难)配置",
        "type": "object",
        "default": {},
        "items": {
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用",
            "hint": "勾选此项以启用分块打乱(困难)效果"
          },
          "difficulty": {
            "type": "int",
            "default": 3,
            "description": "分数",
            "hint": "控制猜对时获得的分数"
          },
          "block_size": {
            "type": "int",
            "default": 20,
            "description": "区块大小",
            "hint": "控制方块的大小，值越小方块越小，打乱程度越高"
          }
        }
      }
    }
  },
  "reward_valid_time": {
    "description": "奖励有效时间（秒）",
    "type": "int",
    "default": 0,
    "hint": "第一个玩家答对后，其他玩家在此时间内答对也能获得分数。设置为0表示禁用此功能（只有第一个答对者得分），设置为大于0的值表示启用功能并设定有效时间（单位：秒）。建议范围：3-15秒"
  }
}
